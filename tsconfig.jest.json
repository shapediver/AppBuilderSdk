{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"module": "commonjs",
		"moduleResolution": "node",
		"baseUrl": "src",
		"paths": {
			"@AppBuilderShared/*": ["./shared/*"],
			"@AppBuilderLib/*": ["./shared/*"],
			"~/*": ["./*"],
			"@modelstorage": ["../modelstorage.ts"]
		},
		"types": [
			"node",
			"@testing-library/jest-dom",
			"vite/client",
			"vite-plugin-svgr/client"
		]
	},
	"include": [
		"src/**/*.test.ts",
		"src/**/*.test.tsx",
		"src/**/*.spec.ts",
		"src/**/*.spec.tsx"
	],
	"exclude": []
}
