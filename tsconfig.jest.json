{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"module": "commonjs",
		"moduleResolution": "node",
		"types": [
			"node",
			"@testing-library/jest-dom",
			"vite/client",
			"vite-plugin-svgr/client"
		]
	},
	"include": [
		"src/**/*.test.ts",
		"src/**/*.test.tsx",
		"src/**/*.spec.ts",
		"src/**/*.spec.tsx",
		"tests/jest.setup.ts",
		"tests/mocks/**/*.ts",
		"tests/mocks/**/*.tsx"
	],
	"exclude": []
}
